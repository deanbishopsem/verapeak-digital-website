---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/assets/logo.svg" alt="Verapeak Digital" width="180" height="67" />
      <p>Data-driven digital marketing that moves your numbers in the right direction.</p>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <a href="/">Home</a>
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Services</h4>
      <a href="/services">SEO</a>
      <a href="/services">Paid Media</a>
      <a href="/services">Web Design</a>
      <a href="/services">Analytics</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <a href="mailto:hello@verapeakdigital.com">hello@verapeakdigital.com</a>
      <a href="tel:+18005551234">(800) 555-1234</a>
      <a href="/contact">Request a proposal</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Verapeak Digital. All rights reserved.</span>
    <div class="footer-legal">
      <a href="#">Privacy</a>
      <a href="#">Terms</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: #cfe3e1;
    padding-top: 72px;
    margin-top: auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: 48px;
  }
  .footer-brand img {
    height: 40px;
    width: auto;
    background: #fff;
    border-radius: 10px;
    padding: 8px 12px;
  }
  .footer-brand p {
    margin-top: 18px;
    color: #9fc0bc;
    max-width: 34ch;
  }
  .footer-col h4 {
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .footer-col a {
    display: block;
    color: #9fc0bc;
    padding: 6px 0;
    font-size: 0.95rem;
  }
  .footer-col a:hover { color: var(--mint-light); }
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-block: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.88rem;
    color: #8fb3af;
  }
  .footer-legal { display: flex; gap: 20px; }
  .footer-legal a { color: #8fb3af; }
  .footer-legal a:hover { color: var(--mint-light); }

  @media (min-width: 720px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1.4fr; }
    .footer-bottom { flex-direction: row; justify-content: space-between; align-items: center; }
  }
</style>
