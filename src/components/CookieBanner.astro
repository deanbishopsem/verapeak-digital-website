---

<div class="cookie-banner" id="cookie-banner" role="dialog" aria-label="Cookie consent" aria-live="polite" hidden>
  <p class="cookie-text">
    We use cookies to understand where our traffic comes from and improve the site.
    You can accept or decline analytics tracking.
  </p>
  <div class="cookie-actions">
    <button class="cookie-btn cookie-decline" type="button">Decline</button>
    <button class="cookie-btn cookie-accept" type="button">Accept</button>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    left: 18px;
    right: 18px;
    bottom: 18px;
    z-index: 200;
    margin-inline: auto;
    max-width: 560px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    padding: 18px 20px;
    background: linear-gradient(160deg, var(--ink) 0%, var(--teal-dark) 160%);
    color: #dcebe8;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    animation: cookieUp 0.4s var(--ease) both;
  }
  .cookie-text { margin: 0; flex: 1 1 240px; font-size: 0.92rem; line-height: 1.5; color: #cfe3de; }
  .cookie-actions { display: flex; gap: 10px; flex: 0 0 auto; }
  .cookie-btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: transform 0.15s var(--ease), background 0.2s var(--ease), border-color 0.2s var(--ease);
  }
  .cookie-btn:active { transform: translateY(1px); }
  .cookie-accept { background: var(--mint); color: var(--ink); }
  .cookie-accept:hover { background: var(--mint-light); }
  .cookie-decline { background: transparent; color: #cfe3de; border-color: rgba(255, 255, 255, 0.3); }
  .cookie-decline:hover { border-color: #fff; color: #fff; }

  @keyframes cookieUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

  @media (max-width: 520px) {
    .cookie-actions { flex: 1 1 100%; }
    .cookie-btn { flex: 1; }
  }
</style>

<script>
  const banner = document.getElementById('cookie-banner');
  const KEY = 'vp-consent';

  const setConsent = (value: 'granted' | 'denied') => {
    try { localStorage.setItem(KEY, value); } catch (e) {}
    const gtag = (window as any).gtag;
    if (value === 'granted' && typeof gtag === 'function') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
    banner?.setAttribute('hidden', '');
  };

  let stored: string | null = null;
  try { stored = localStorage.getItem(KEY); } catch (e) {}
  if (!stored) banner?.removeAttribute('hidden');

  banner?.querySelector('.cookie-accept')?.addEventListener('click', () => setConsent('granted'));
  banner?.querySelector('.cookie-decline')?.addEventListener('click', () => setConsent('denied'));
</script>
