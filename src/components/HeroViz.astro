---
interface Props {
  variant: string;
}
const { variant } = Astro.props;

const meta: Record<string, { title: string; chip: string; foot: [string, string] }> = {
  growth: { title: 'Full-funnel growth', chip: 'live', foot: ['<b>4x+</b> ROAS target', '<b>2x</b> organic, yr 1'] },
  reach: { title: 'Knoxville to nationwide', chip: 'reach', foot: ['Based in <b>Knoxville</b>', 'Serving the <b>US</b>'] },
  seo: { title: 'Search visibility', chip: 'rank', foot: ['<b>#1</b> ranking goal', '<b>+212%</b> organic'] },
  paid: { title: 'Return on ad spend', chip: 'ROAS', foot: ['<b>$1</b> in', '<b>$4.80</b> back'] },
  web: { title: 'Built to convert', chip: 'CRO', foot: ['<b>+30%</b> conversion', '<b>&lt;2.5s</b> load'] },
  analytics: { title: 'One source of truth', chip: 'live', foot: ['<b>100%</b> spend visibility', '<b>GA4</b> + attribution'] },
  email: { title: 'Lifecycle on autopilot', chip: 'auto', foot: ['<b>6.2x</b> example ROAS', '<b>Owned</b> audience'] },
  brand: { title: 'Positioning', chip: 'clarity', foot: ['<b>One</b> clear message', '<b>Top-right</b> is the win'] },
  blog: { title: 'Marketing playbook', chip: 'new', foot: ['<b>How-tos</b> & deep dives', '<b>Small-business</b> focused'] },
};
const m = meta[variant] ?? meta.growth;
---

<div class:list={['hv-card', `hv-${variant}`]}>
  <div class="hv-head">
    <span class="hv-title">{m.title}</span>
    <span class="hv-chip"><span class="hv-dotlive"></span>{m.chip}</span>
  </div>

  <svg viewBox="0 0 460 280" class="hv-svg" role="img" aria-label={`Animated illustration: ${m.title}`}>
    <defs>
      <linearGradient id={`hvArea-${variant}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#2DD4BF" stop-opacity="0.32" />
        <stop offset="100%" stop-color="#2DD4BF" stop-opacity="0" />
      </linearGradient>
    </defs>

    {variant === 'growth' && (
      <g>
        <g stroke="rgba(255,255,255,0.07)"><line x1="36" y1="80" x2="424" y2="80" /><line x1="36" y1="140" x2="424" y2="140" /><line x1="36" y1="200" x2="424" y2="200" /></g>
        <g class="hv-bars">
          <rect class="bar" x="44" y="185" width="38" height="55" rx="5" /><rect class="bar" x="108" y="160" width="38" height="80" rx="5" /><rect class="bar" x="172" y="130" width="38" height="110" rx="5" /><rect class="bar" x="236" y="100" width="38" height="140" rx="5" /><rect class="bar" x="300" y="65" width="38" height="175" rx="5" /><rect class="bar" x="364" y="30" width="38" height="210" rx="5" />
        </g>
        <path class="harea" d="M63 185 L127 160 L191 130 L255 100 L319 65 L383 30 L383 240 L63 240 Z" fill={`url(#hvArea-${variant})`} />
        <path class="gline" pathLength="1" d="M63 185 L127 160 L191 130 L255 100 L319 65 L383 30" fill="none" stroke="#5EEAD4" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        <circle class="gring" cx="383" cy="30" r="9" fill="none" stroke="#5EEAD4" stroke-width="2" /><circle class="gdot" cx="383" cy="30" r="6" fill="#5EEAD4" />
      </g>
    )}

    {variant === 'reach' && (
      <g>
        <g fill="#7fd8c9" class="hv-cities"><circle class="city" cx="120" cy="92" r="3" /><circle class="city" cx="350" cy="80" r="3" /><circle class="city" cx="80" cy="180" r="3" /><circle class="city" cx="380" cy="170" r="3" /><circle class="city" cx="170" cy="210" r="3" /><circle class="city" cx="300" cy="205" r="3" /><circle class="city" cx="250" cy="70" r="3" /><circle class="city" cx="160" cy="120" r="3" /></g>
        <g stroke="rgba(94,234,212,0.25)" stroke-width="1" fill="none"><line x1="230" y1="150" x2="120" y2="92" /><line x1="230" y1="150" x2="350" y2="80" /><line x1="230" y1="150" x2="80" y2="180" /><line x1="230" y1="150" x2="380" y2="170" /><line x1="230" y1="150" x2="300" y2="205" /><line x1="230" y1="150" x2="160" y2="120" /></g>
        <circle class="ring" cx="230" cy="150" r="24" fill="none" stroke="#5EEAD4" stroke-width="2" /><circle class="ring" cx="230" cy="150" r="24" fill="none" stroke="#5EEAD4" stroke-width="2" /><circle class="ring" cx="230" cy="150" r="24" fill="none" stroke="#5EEAD4" stroke-width="2" />
        <circle class="hub-glow" cx="230" cy="150" r="16" fill="rgba(45,212,191,0.25)" /><circle class="hub" cx="230" cy="150" r="8" fill="#5EEAD4" />
        <text x="230" y="186" text-anchor="middle" font-size="13" font-weight="600" fill="#cdeee7" font-family="Helvetica, Arial, sans-serif">Knoxville, TN</text>
      </g>
    )}

    {variant === 'seo' && (
      <g>
        <rect x="40" y="26" width="380" height="40" rx="12" fill="#0a1714" stroke="rgba(255,255,255,0.12)" />
        <circle cx="70" cy="46" r="8" fill="none" stroke="#5EEAD4" stroke-width="2" /><line x1="76" y1="52" x2="84" y2="60" stroke="#5EEAD4" stroke-width="2" />
        <rect x="96" y="42" width="150" height="8" rx="4" fill="rgba(255,255,255,0.22)" /><rect class="hv-caret" x="250" y="38" width="2" height="16" fill="#5EEAD4" />
        <g class="seo-rows">
          <g class="seo-row seo-win"><rect x="40" y="92" width="380" height="46" rx="10" fill="rgba(45,212,191,0.10)" stroke="rgba(94,234,212,0.4)" /><rect x="58" y="104" width="150" height="9" rx="4" fill="#5EEAD4" /><rect x="58" y="120" width="250" height="6" rx="3" fill="rgba(255,255,255,0.2)" /><rect class="seo-badge" x="350" y="104" width="52" height="22" rx="11" fill="#5EEAD4" /><text class="seo-badge-t" x="376" y="119" text-anchor="middle" font-size="12" font-weight="700" fill="#06201b" font-family="Helvetica, Arial">#1</text></g>
          <g class="seo-row"><rect x="58" y="156" width="120" height="8" rx="4" fill="rgba(255,255,255,0.3)" /><rect x="58" y="170" width="280" height="6" rx="3" fill="rgba(255,255,255,0.12)" /></g>
          <g class="seo-row"><rect x="58" y="196" width="120" height="8" rx="4" fill="rgba(255,255,255,0.3)" /><rect x="58" y="210" width="280" height="6" rx="3" fill="rgba(255,255,255,0.12)" /></g>
          <g class="seo-row"><rect x="58" y="236" width="120" height="8" rx="4" fill="rgba(255,255,255,0.3)" /><rect x="58" y="250" width="280" height="6" rx="3" fill="rgba(255,255,255,0.12)" /></g>
        </g>
      </g>
    )}

    {variant === 'paid' && (
      <g>
        <circle class="tgt tgt1" cx="230" cy="140" r="96" fill="none" stroke="rgba(94,234,212,0.25)" stroke-width="2" />
        <circle class="tgt tgt2" cx="230" cy="140" r="64" fill="none" stroke="rgba(94,234,212,0.4)" stroke-width="2" />
        <circle class="tgt tgt3" cx="230" cy="140" r="32" fill="rgba(45,212,191,0.12)" stroke="#5EEAD4" stroke-width="2" />
        <line x1="110" y1="140" x2="350" y2="140" stroke="rgba(255,255,255,0.12)" stroke-width="1" /><line x1="230" y1="20" x2="230" y2="260" stroke="rgba(255,255,255,0.12)" stroke-width="1" />
        <g class="paid-pin"><line x1="230" y1="60" x2="230" y2="140" stroke="#5EEAD4" stroke-width="2.5" /><circle cx="230" cy="140" r="7" fill="#5EEAD4" /></g>
        <circle class="paid-burst" cx="230" cy="140" r="10" fill="none" stroke="#5EEAD4" stroke-width="2" />
        <text class="paid-num" x="230" y="146" text-anchor="middle" font-size="30" font-weight="800" fill="#fff" font-family="Helvetica, Arial" opacity="0">4.8×</text>
      </g>
    )}

    {variant === 'web' && (
      <g>
        <rect x="44" y="30" width="372" height="222" rx="14" fill="#0a1714" stroke="rgba(255,255,255,0.1)" />
        <line x1="44" y1="60" x2="416" y2="60" stroke="rgba(255,255,255,0.08)" />
        <circle cx="64" cy="45" r="4" fill="rgba(255,255,255,0.25)" /><circle cx="80" cy="45" r="4" fill="rgba(255,255,255,0.25)" /><circle cx="96" cy="45" r="4" fill="rgba(255,255,255,0.25)" /><rect x="150" y="39" width="160" height="12" rx="6" fill="rgba(255,255,255,0.07)" />
        <rect class="wblk" x="68" y="80" width="200" height="14" rx="5" fill="rgba(94,234,212,0.5)" /><rect class="wblk" x="68" y="104" width="150" height="9" rx="4" fill="rgba(255,255,255,0.2)" />
        <rect class="wblk wcta" x="68" y="130" width="120" height="34" rx="9" fill="#2DD4BF" /><text x="128" y="152" text-anchor="middle" font-size="13" font-weight="700" fill="#06201b" font-family="Helvetica, Arial" class="wblk">Get started</text>
        <rect class="wblk" x="300" y="80" width="92" height="84" rx="10" fill="rgba(255,255,255,0.06)" />
        <rect class="wblk" x="68" y="186" width="324" height="9" rx="4" fill="rgba(255,255,255,0.12)" /><rect class="wblk" x="68" y="206" width="240" height="9" rx="4" fill="rgba(255,255,255,0.1)" />
        <g class="web-cursor"><path d="M0 0 L0 17 L4.6 13 L7.7 19.8 L10.1 18.5 L7 12 L13 12 Z" fill="#fff" stroke="#06201b" stroke-width="1" /></g>
        <circle class="web-ripple" cx="128" cy="147" r="6" fill="none" stroke="#5EEAD4" stroke-width="2" />
      </g>
    )}

    {variant === 'analytics' && (
      <g>
        <rect class="aw" x="44" y="30" width="180" height="110" rx="12" fill="#0a1714" stroke="rgba(255,255,255,0.1)" />
        <rect x="60" y="46" width="70" height="7" rx="3" fill="rgba(255,255,255,0.25)" />
        <g stroke="rgba(255,255,255,0.06)"><line x1="60" y1="92" x2="208" y2="92" /><line x1="60" y1="112" x2="208" y2="112" /></g>
        <path class="aline" pathLength="1" d="M60 120 L86 110 L112 116 L138 96 L164 100 L190 78 L208 70" fill="none" stroke="#5EEAD4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        <rect class="aw" x="236" y="30" width="180" height="52" rx="12" fill="#0a1714" stroke="rgba(255,255,255,0.1)" /><text x="252" y="58" font-size="22" font-weight="800" fill="#fff" font-family="Helvetica, Arial">4.8×</text><text x="330" y="58" font-size="11" fill="#34D399" font-family="Helvetica, Arial">▲ ROAS</text>
        <rect class="aw" x="236" y="92" width="180" height="48" rx="12" fill="#0a1714" stroke="rgba(255,255,255,0.1)" />
        <g class="abars"><rect class="abar" x="252" y="104" width="14" height="26" rx="3" fill="rgba(94,234,212,0.5)" /><rect class="abar" x="274" y="104" width="14" height="26" rx="3" fill="rgba(94,234,212,0.5)" /><rect class="abar" x="296" y="104" width="14" height="26" rx="3" fill="rgba(94,234,212,0.5)" /><rect class="abar" x="318" y="104" width="14" height="26" rx="3" fill="rgba(94,234,212,0.5)" /><rect class="abar" x="340" y="104" width="14" height="26" rx="3" fill="#2DD4BF" /></g>
        <rect class="aw" x="44" y="152" width="372" height="96" rx="12" fill="#0a1714" stroke="rgba(255,255,255,0.1)" />
        <rect x="60" y="168" width="90" height="7" rx="3" fill="rgba(255,255,255,0.25)" />
        <g stroke="rgba(255,255,255,0.06)"><line x1="60" y1="232" x2="400" y2="232" /></g>
        <path class="aline2" pathLength="1" d="M60 224 L110 214 L160 218 L210 198 L260 204 L310 180 L360 168 L400 150" fill="none" stroke="#7fd8c9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </g>
    )}

    {variant === 'email' && (
      <g>
        <line x1="120" y1="150" x2="360" y2="150" stroke="rgba(255,255,255,0.12)" stroke-width="2" stroke-dasharray="2 6" />
        <g class="mail-icon"><rect x="40" y="120" width="64" height="46" rx="8" fill="rgba(45,212,191,0.14)" stroke="#5EEAD4" stroke-width="2" /><path d="M44 126 L72 146 L100 126" fill="none" stroke="#5EEAD4" stroke-width="2" /></g>
        <g class="node"><circle cx="160" cy="150" r="16" fill="#0a1714" stroke="#5EEAD4" stroke-width="2" /><text x="160" y="154" text-anchor="middle" font-size="10" fill="#cdeee7" font-family="Helvetica, Arial">Hi</text></g>
        <g class="node"><circle cx="260" cy="150" r="16" fill="#0a1714" stroke="#5EEAD4" stroke-width="2" /><circle cx="260" cy="150" r="4" fill="#5EEAD4" /></g>
        <g class="node"><circle cx="360" cy="150" r="16" fill="#0a1714" stroke="#5EEAD4" stroke-width="2" /><path d="M353 150 l5 5 l9 -10" fill="none" stroke="#5EEAD4" stroke-width="2" /></g>
        <circle class="flow-dot d1" cx="120" cy="150" r="4" fill="#5EEAD4" /><circle class="flow-dot d2" cx="120" cy="150" r="4" fill="#5EEAD4" /><circle class="flow-dot d3" cx="120" cy="150" r="4" fill="#5EEAD4" />
        <text x="160" y="196" text-anchor="middle" font-size="11" fill="#9fc7c0" font-family="Helvetica, Arial">Welcome</text><text x="260" y="196" text-anchor="middle" font-size="11" fill="#9fc7c0" font-family="Helvetica, Arial">Nurture</text><text x="360" y="196" text-anchor="middle" font-size="11" fill="#9fc7c0" font-family="Helvetica, Arial">Convert</text>
      </g>
    )}

    {variant === 'brand' && (
      <g>
        <line class="qaxis" x1="230" y1="36" x2="230" y2="244" stroke="rgba(255,255,255,0.14)" stroke-width="1.5" /><line class="qaxis" x1="60" y1="140" x2="400" y2="140" stroke="rgba(255,255,255,0.14)" stroke-width="1.5" />
        <text x="394" y="132" text-anchor="end" font-size="10" fill="#6f8882" font-family="Helvetica, Arial">Broad</text><text x="236" y="46" font-size="10" fill="#6f8882" font-family="Helvetica, Arial">Premium</text>
        <g class="comp" fill="rgba(255,255,255,0.28)"><circle cx="120" cy="190" r="6" /><circle cx="170" cy="170" r="6" /><circle cx="150" cy="100" r="6" /><circle cx="290" cy="200" r="6" /><circle cx="250" cy="120" r="6" /></g>
        <circle class="brand-glow" cx="330" cy="86" r="18" fill="rgba(45,212,191,0.22)" />
        <circle class="brand-you" cx="330" cy="86" r="9" fill="#5EEAD4" />
        <text class="brand-label" x="330" y="68" text-anchor="middle" font-size="11" font-weight="700" fill="#cdeee7" font-family="Helvetica, Arial">You</text>
      </g>
    )}

    {variant === 'blog' && (
      <g>
        <rect x="60" y="34" width="340" height="212" rx="14" fill="#0a1714" stroke="rgba(255,255,255,0.1)" />
        <rect class="blog-tag" x="80" y="54" width="92" height="22" rx="11" fill="rgba(45,212,191,0.16)" stroke="rgba(94,234,212,0.4)" /><path class="blog-tag" d="M92 67 l6 -6 l5 4 l9 -9" fill="none" stroke="#5EEAD4" stroke-width="2" /><text class="blog-tag" x="120" y="69" font-size="10" fill="#9fe8db" font-family="Helvetica, Arial">Trending</text>
        <rect class="bline" x="80" y="92" width="280" height="14" rx="5" fill="rgba(255,255,255,0.85)" /><rect class="bline" x="80" y="112" width="220" height="14" rx="5" fill="rgba(255,255,255,0.6)" />
        <rect class="bline" x="80" y="146" width="300" height="8" rx="4" fill="rgba(255,255,255,0.18)" /><rect class="bline" x="80" y="164" width="300" height="8" rx="4" fill="rgba(255,255,255,0.18)" /><rect class="bline" x="80" y="182" width="240" height="8" rx="4" fill="rgba(255,255,255,0.18)" />
        <rect class="bsweep" x="80" y="92" width="60" height="14" rx="5" fill="rgba(94,234,212,0.4)" />
        <rect class="bline" x="80" y="210" width="120" height="10" rx="5" fill="#2DD4BF" />
      </g>
    )}
  </svg>

  <div class="hv-foot">
    <span set:html={m.foot[0]} />
    <span set:html={m.foot[1]} />
  </div>
</div>

<style>
  .hv-card {
    background:
      radial-gradient(120% 130% at 85% -10%, rgba(45, 212, 191, 0.18) 0%, transparent 55%),
      linear-gradient(160deg, var(--ink) 0%, var(--teal-dark) 140%);
    border-radius: var(--radius-lg);
    padding: 22px 22px 18px;
    box-shadow: var(--shadow-lg);
  }
  .hv-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .hv-title { color: #fff; font-weight: 600; font-size: 1rem; }
  .hv-chip { display: inline-flex; align-items: center; gap: 7px; font-size: 0.74rem; font-weight: 600; color: var(--ink); background: var(--mint); padding: 5px 11px; border-radius: var(--radius-pill); text-transform: capitalize; }
  .hv-dotlive { width: 6px; height: 6px; border-radius: 50%; background: var(--ink); animation: hvBlink 1.6s ease-in-out infinite; }
  .hv-svg { width: 100%; height: auto; display: block; }
  .hv-foot { display: flex; justify-content: space-between; gap: 12px; margin-top: 10px; color: #9fc7c0; font-size: 0.86rem; }
  .hv-foot :global(b) { color: #fff; font-family: var(--font-display); }

  /* growth */
  .bar { fill: rgba(94, 234, 212, 0.16); transform: scaleY(0); transform-box: fill-box; transform-origin: bottom; animation: hvGrow 0.85s var(--ease) forwards; }
  .hv-bars .bar:nth-child(1) { animation-delay: 0.10s; } .hv-bars .bar:nth-child(2) { animation-delay: 0.18s; } .hv-bars .bar:nth-child(3) { animation-delay: 0.26s; } .hv-bars .bar:nth-child(4) { animation-delay: 0.34s; } .hv-bars .bar:nth-child(5) { animation-delay: 0.42s; } .hv-bars .bar:nth-child(6) { animation-delay: 0.50s; }
  .harea { opacity: 0; animation: hvFade 1s ease 0.6s forwards; }
  .gline { stroke-dasharray: 1; stroke-dashoffset: 1; animation: hvDraw 1.3s var(--ease) 0.5s forwards; }
  .gdot { opacity: 0; transform-box: fill-box; transform-origin: center; animation: hvPop 0.4s ease 1.7s forwards; }
  .gring { opacity: 0; transform-box: fill-box; transform-origin: center; animation: hvPulse 2.4s ease-out 2s infinite; }

  /* reach */
  .ring { transform-box: fill-box; transform-origin: center; opacity: 0; animation: hvRipple 3.6s ease-out infinite; }
  .hv-reach .ring:nth-child(2) { animation-delay: 1.2s; } .hv-reach .ring:nth-child(3) { animation-delay: 2.4s; }
  .hub, .hub-glow { transform-box: fill-box; transform-origin: center; animation: hvBeat 2.4s ease-in-out infinite; }
  .city { opacity: 0.5; transform-box: fill-box; transform-origin: center; animation: hvTwinkle 3s ease-in-out infinite; }
  .hv-cities .city:nth-child(odd) { animation-delay: 1.2s; } .hv-cities .city:nth-child(3n) { animation-delay: 0.6s; }

  /* seo */
  .seo-row { opacity: 0; transform: translateY(14px); transform-box: fill-box; animation: hvSlideUp 0.6s var(--ease) forwards; }
  .seo-rows .seo-row:nth-child(1) { animation-delay: 0.3s; } .seo-rows .seo-row:nth-child(2) { animation-delay: 0.5s; } .seo-rows .seo-row:nth-child(3) { animation-delay: 0.65s; } .seo-rows .seo-row:nth-child(4) { animation-delay: 0.8s; }
  .seo-badge, .seo-badge-t { opacity: 0; transform-box: fill-box; transform-origin: center; animation: hvPop 0.45s ease 1s forwards; }
  .hv-caret { animation: hvBlink 1s step-end infinite; }

  /* paid */
  .tgt { transform-box: fill-box; transform-origin: center; opacity: 0; animation: hvScaleIn 0.6s var(--ease) forwards; }
  .hv-paid .tgt1 { animation-delay: 0.1s; } .hv-paid .tgt2 { animation-delay: 0.25s; } .hv-paid .tgt3 { animation-delay: 0.4s; }
  .paid-pin { opacity: 0; transform: translateY(-50px); transform-box: fill-box; animation: hvDrop 0.6s cubic-bezier(0.5,1.6,0.4,1) 0.9s forwards; }
  .paid-burst { opacity: 0; transform-box: fill-box; transform-origin: center; animation: hvPulse 2.2s ease-out 1.4s infinite; }
  .paid-num { animation: hvPop 0.5s ease 1.5s forwards; transform-box: fill-box; transform-origin: center; }

  /* web */
  .wblk { opacity: 0; transform: translateY(12px); transform-box: fill-box; animation: hvSlideUp 0.5s var(--ease) forwards; }
  .hv-web .wblk:nth-of-type(1) { animation-delay: 0.3s; } .hv-web .wblk:nth-of-type(2) { animation-delay: 0.42s; } .hv-web .wblk:nth-of-type(3) { animation-delay: 0.54s; } .hv-web .wblk:nth-of-type(4) { animation-delay: 0.6s; } .hv-web .wblk:nth-of-type(5) { animation-delay: 0.66s; } .hv-web .wblk:nth-of-type(6) { animation-delay: 0.78s; } .hv-web .wblk:nth-of-type(7) { animation-delay: 0.9s; }
  .wcta { animation: hvSlideUp 0.5s var(--ease) 0.54s forwards, hvCtaPulse 2s ease-in-out 2s infinite; }
  .web-cursor { transform: translate(260px, 200px); animation: hvCursor 2.6s ease-in-out 1.4s infinite; }
  .web-ripple { opacity: 0; transform-box: fill-box; transform-origin: center; animation: hvRipple2 2.6s ease-out 1.4s infinite; }

  /* analytics */
