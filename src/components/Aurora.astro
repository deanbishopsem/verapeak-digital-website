---
// Soft, slow-drifting aurora background. Drop inside a `.has-aurora` section
// (which provides position:relative + overflow:hidden) as the first child.
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
---

<div class:list={['aurora', `aurora-${variant}`]} aria-hidden="true">
  <span class="aurora-b b1"></span>
  <span class="aurora-b b2"></span>
  <span class="aurora-b b3"></span>
</div>

<style>
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .aurora-b {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform;
  }

  /* light sections */
  .aurora-light .b1 {
    width: min(46vw, 620px); height: min(46vw, 620px);
    top: -16%; right: -8%;
    background: rgba(45, 212, 191, 0.18);
    animation: auroraA 26s ease-in-out infinite alternate;
  }
  .aurora-light .b2 {
    width: min(38vw, 520px); height: min(38vw, 520px);
    bottom: -22%; left: -10%;
    background: rgba(15, 118, 110, 0.14);
    animation: auroraB 32s ease-in-out infinite alternate;
  }
  .aurora-light .b3 {
    width: min(30vw, 420px); height: min(30vw, 420px);
    top: 24%; left: 46%;
    background: rgba(94, 234, 212, 0.12);
    animation: auroraC 22s ease-in-out infinite alternate;
  }

  /* dark sections */
  .aurora-dark .b1 {
    width: min(46vw, 620px); height: min(46vw, 620px);
    top: -18%; right: -6%;
    background: rgba(45, 212, 191, 0.28);
    animation: auroraA 26s ease-in-out infinite alternate;
  }
  .aurora-dark .b2 {
    width: min(38vw, 520px); height: min(38vw, 520px);
    bottom: -24%; left: -8%;
    background: rgba(15, 118, 110, 0.3);
    animation: auroraB 32s ease-in-out infinite alternate;
  }
  .aurora-dark .b3 {
    width: min(30vw, 420px); height: min(30vw, 420px);
    top: 20%; left: 50%;
    background: rgba(94, 234, 212, 0.18);
    animation: auroraC 22s ease-in-out infinite alternate;
  }

  @keyframes auroraA { from { transform: translate(0, 0) scale(1); } to { transform: translate(-7%, 9%) scale(1.08); } }
  @keyframes auroraB { from { transform: translate(0, 0) scale(1); } to { transform: translate(9%, -6%) scale(1.1); } }
  @keyframes auroraC { from { transform: translate(0, 0) scale(1); } to { transform: translate(-5%, -8%) scale(1.06); } }

  @media (prefers-reduced-motion: reduce) {
    .aurora-b { animation: none; }
  }
</style>
