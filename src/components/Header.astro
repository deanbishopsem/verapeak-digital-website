---
import { services } from '../data/services';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Verapeak Digital home">
      <img class="logo-dark" src="/assets/logo-tight.svg" alt="Verapeak Digital" width="349" height="89" />
      <img class="logo-light" src="/assets/logo-tight-light.svg" alt="Verapeak Digital" width="349" height="89" />
    </a>

    <nav class="nav" aria-label="Primary">
      {links.map((l) => (
        l.href === '/services' ? (
          <div class="nav-item has-dropdown">
            <a href="/services" class:list={['nav-link', { active: isActive('/services') }]}>
              Services<span class="caret" aria-hidden="true"></span>
            </a>
            <div class="dropdown">
              <div class="dropdown-card">
                {services.map((s) => (
                  <a href={`/services/${s.slug}`} class="dropdown-link">{s.name}</a>
                ))}
                <a href="/services" class="dropdown-link dropdown-all">All services <span aria-hidden="true">&rarr;</span></a>
              </div>
            </div>
          </div>
        ) : (
          <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>
            {l.label}
          </a>
        )
      ))}
    </nav>

    <a href="https://app.verapeakdigital.com/" target="_blank" rel="noopener" class="client-cta">
      Client Login
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <a href="/contact" class="btn btn-primary header-cta">Get a proposal</a>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" aria-label="Mobile">
    {links.map((l) => (
      <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>
        {l.label}
      </a>
    ))}
    <a href="https://app.verapeakdigital.com/" target="_blank" rel="noopener" class="nav-link mobile-client">Client Login &#8599;</a>
    <a href="/contact" class="btn btn-primary">Get a proposal</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--border);
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    height: 60px;
  }
  .brand { position: relative; display: block; }
  .brand img { height: 44px; width: auto; display: block; transition: opacity 0.35s var(--ease); }
  .brand .logo-light { position: absolute; inset: 0; opacity: 0; }

  /* Transparent state while over the dark hero */
  .site-header.over-hero {
    background: transparent;
    backdrop-filter: none;
    border-color: transparent;
  }
  .site-header.over-hero .logo-dark { opacity: 0; }
  .site-header.over-hero .logo-light { opacity: 1; }
  .site-header.over-hero .nav-link { color: rgba(255, 255, 255, 0.86); }
  .site-header.over-hero .nav-link:hover { color: #fff; background: rgba(255, 255, 255, 0.12); }
  .site-header.over-hero .nav-link.active { color: var(--mint-light); }
  .site-header.over-hero .header-cta {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    box-shadow: none;
  }
  .site-header.over-hero .header-cta:hover { background: rgba(255, 255, 255, 0.2); }
  .site-header.over-hero .menu-toggle { border-color: rgba(255, 255, 255, 0.4); }
  .site-header.over-hero .menu-toggle span { background: #fff; }

  /* Mobile menu open: force a solid, readable header even over the dark hero */
  .site-header.nav-open {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: saturate(180%) blur(16px);
    border-color: var(--border);
  }
  .site-header.nav-open .logo-dark { opacity: 1; }
  .site-header.nav-open .logo-light { opacity: 0; }
  .site-header.nav-open .nav-link { color: var(--text); }
  .site-header.nav-open .nav-link.active { color: var(--teal); }
  .site-header.nav-open .menu-toggle { border-color: var(--border-strong); }
  .site-header.nav-open .menu-toggle span { background: var(--ink); }

  .nav { display: none; gap: 6px; margin-left: auto; }
  .nav-link {
    color: var(--text);
    font-weight: 500;
    font-size: 0.97rem;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    transition: color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .nav-link:hover { color: var(--ink); background: var(--bg-tint); }
  .nav-link.active { color: var(--teal); }

  /* Services hover dropdown */
  .nav-item { position: relative; display: flex; }
  .nav-item .nav-link { display: inline-flex; align-items: center; gap: 6px; }
  .caret { width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid currentColor; opacity: 0.6; transition: transform 0.2s var(--ease); }
  .has-dropdown:hover .caret { transform: rotate(180deg); }
  .dropdown {
    position: absolute; top: 100%; left: 0; padding-top: 12px; z-index: 60;
    opacity: 0; visibility: hidden; transform: translateY(6px);
    transition: opacity 0.2s var(--ease), transform 0.2s var(--ease), visibility 0.2s;
  }
  .has-dropdown:hover .dropdown, .has-dropdown:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-card {
    min-width: 264px; background: #fff; border: 1px solid var(--border);
    border-radius: 14px; box-shadow: var(--shadow-lg); padding: 8px; display: grid; gap: 2px;
  }
  .dropdown-link {
    display: block; padding: 10px 13px; border-radius: 9px; font-size: 0.95rem;
    font-weight: 500; color: var(--text);
  }
  .dropdown-link:hover { background: var(--bg-tint); color: var(--teal); }
  .dropdown-all { color: var(--teal); font-weight: 600; border-top: 1px solid var(--border); border-radius: 0 0 9px 9px; margin-top: 4px; }
  .site-header.over-hero .caret { border-top-color: rgba(255, 255, 255, 0.86); }

  .header-cta { display: none; padding: 11px 22px; font-size: 0.95rem; }

  /* Client dashboard login (secondary, ghost) */
  .client-cta {
    display: none;
    align-items: center;
    gap: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 10px 16px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--border-strong);
    color: var(--ink);
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .client-cta:hover { border-color: var(--teal); color: var(--teal); }
  .client-cta svg { opacity: 0.7; }
  .site-header.over-hero .client-cta { border-color: rgba(255, 255, 255, 0.35); color: #fff; }
  .site-header.over-hero .client-cta:hover { border-color: #fff; background: rgba(255, 255, 255, 0.12); }
  .mobile-client { color: var(--teal) !important; font-weight: 600; }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px; height: 44px;
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 12px;
  }
  .menu-toggle span {
    display: block;
    width: 19px; height: 2px;
    margin-inline: auto;
    background: var(--ink);
    border-radius: 2px;
  }
  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 2px;
    padding: 14px 28px 26px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav .nav-link { padding: 12px 4px; font-size: 1.05rem; }
  .mobile-nav .btn { margin-top: 12px; justify-content: center; }

  @media (min-width: 920px) {
    .nav { display: flex; }
    .header-cta { display: inline-flex; }
    .client-cta { display: inline-flex; }
    .menu-toggle { display: none; }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('open');
    header?.classList.toggle('nav-open', !!open);
    toggle.setAttribute('aria-expanded', String(!!open));
  });

  // Transparent header while a dark hero sits behind it (home page only).
  const darkHero = document.querySelector('[data-hero-dark]');
  if (header && darkHero) {
    const apply = () => {
      const r = darkHero.getBoundingClientRect();
      header.classList.toggle('over-hero', r.bottom > 61);
    };
    apply();
    const io = new IntersectionObserver(() => apply(), {
      rootMargin: '-61px 0px 0px 0px',
      threshold: [0, 1],
    });
    io.observe(darkHero);
  }
</script>
