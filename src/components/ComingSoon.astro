---
// Standalone "coming soon" page — shown for every route while the site is paused.
// IMPORTANT: all styles are scoped to .cs-* classes (no bare body/html/* selectors)
// so this component can be bundled alongside the full site without leaking globals.
const title = 'Verapeak Digital · Coming Soon';
const description = 'Verapeak Digital is launching soon. Data-driven digital marketing that moves your numbers.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-square.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="cs-wrap">
      <div class="cs-inner">
        <div class="cs-logo">
          <img src="/assets/logo.svg" alt="Verapeak Digital" width="200" height="75" />
        </div>

        <div class="cs-dots" aria-hidden="true"><span></span><span></span><span></span></div>

        <div><span class="cs-badge">Coming Soon</span></div>

        <h1 class="cs-h1">Something great is <span class="cs-grad">on the way</span>.</h1>
        <p class="cs-lead">
          We're putting the finishing touches on the new Verapeak Digital. Data-driven
          marketing that moves your numbers, launching shortly.
        </p>

        <a class="cs-cta" href="mailto:contact@verapeakdigital.com?subject=Verapeak%20Digital%20enquiry">
          Get in touch &rarr;
        </a>

        <p class="cs-meta">
          Questions? <a href="mailto:contact@verapeakdigital.com">contact@verapeakdigital.com</a>
        </p>
      </div>
    </main>
  </body>
</html>

<style>
  .cs-wrap {
    box-sizing: border-box;
    position: fixed;
    inset: 0;
    overflow-y: auto;
    display: grid;
    place-items: center;
    padding: 32px;
    text-align: center;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    color: #e7f4f2;
    background:
      radial-gradient(110% 110% at 80% 0%, rgba(45, 212, 191, 0.18) 0%, transparent 55%),
      radial-gradient(90% 90% at 0% 100%, rgba(15, 118, 110, 0.35) 0%, transparent 60%),
      #0f2a2e;
    -webkit-font-smoothing: antialiased;
  }
  .cs-wrap *, .cs-wrap *::before, .cs-wrap *::after { box-sizing: border-box; }
  .cs-inner { max-width: 560px; width: 100%; }
  .cs-logo {
    background: #fff;
    border-radius: 16px;
    padding: 18px 24px;
    display: inline-block;
    margin-bottom: 40px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
  }
  .cs-logo img { height: 48px; width: auto; display: block; }
  .cs-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5eead4;
    border: 1px solid rgba(94, 234, 212, 0.35);
    background: rgba(94, 234, 212, 0.08);
    padding: 7px 16px;
    border-radius: 999px;
    margin-bottom: 28px;
  }
  .cs-h1 {
    margin: 0 0 18px;
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    font-weight: 800;
  }
  .cs-grad {
    background: linear-gradient(110deg, #5eead4, #2dd4bf);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .cs-lead {
    font-size: 1.12rem;
    line-height: 1.6;
    color: #b9d6d2;
    max-width: 46ch;
    margin: 0 auto 36px;
  }
  .cs-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 1rem;
    color: #0f2a2e;
    background: linear-gradient(110deg, #5eead4, #2dd4bf);
    padding: 14px 28px;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 12px 30px rgba(45, 212, 191, 0.25);
  }
  .cs-cta:hover { transform: translateY(-2px); box-shadow: 0 16px 38px rgba(45, 212, 191, 0.35); }
  .cs-meta { margin: 44px 0 0; font-size: 0.9rem; color: #8fb3af; }
  .cs-meta a { color: #5eead4; text-decoration: none; }
  .cs-meta a:hover { text-decoration: underline; }
  .cs-dots { display: inline-flex; gap: 6px; margin-bottom: 28px; }
  .cs-dots span {
    width: 8px; height: 8px; border-radius: 50%;
    background: #2dd4bf;
    animation: cs-pulse 1.4s ease-in-out infinite;
  }
  .cs-dots span:nth-child(2) { animation-delay: 0.2s; opacity: 0.7; }
  .cs-dots span:nth-child(3) { animation-delay: 0.4s; opacity: 0.45; }
  @keyframes cs-pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.5); } }

  @media (prefers-reduced-motion: reduce) {
    .cs-dots span { animation: none; }
  }
</style>
