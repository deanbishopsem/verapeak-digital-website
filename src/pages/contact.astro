---
import Base from '../layouts/Base.astro';

const services = ['SEO', 'Paid Media & PPC', 'Web Design & Development', 'Analytics & CRO', 'Email & Lifecycle', 'Brand & Strategy', 'Not sure yet'];
const budgets = ['< $2k / mo', '$2k – $5k / mo', '$5k – $10k / mo', '$10k+ / mo', "One-off project"];
---

<Base title="Contact — Verapeak Digital" description="Get in touch with Verapeak Digital for a free growth audit and proposal.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about your <span class="text-grad">growth</span>.</h1>
      <p class="lead">
        Tell us where you are and where you want to be. We'll get back within one
        business day with honest, actionable next steps.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <form class="card contact-form" id="contact-form">
        <div class="field-row">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required placeholder="Jane Doe" />
          </div>
          <div class="field">
            <label for="company">Company</label>
            <input id="company" name="company" type="text" placeholder="Acme Inc." />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required placeholder="jane@acme.com" />
          </div>
          <div class="field">
            <label for="website">Website</label>
            <input id="website" name="website" type="url" placeholder="https://acme.com" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="service">Primary interest</label>
            <select id="service" name="service">
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="budget">Monthly budget</label>
            <select id="budget" name="budget">
              {budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div class="field">
          <label for="message">How can we help?</label>
          <textarea id="message" name="message" rows="5" required placeholder="A few sentences about your goals…"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Send Message</button>
        <p class="form-note" id="form-note" hidden>
          ✓ Thanks! This is a demo form — connect it to your CRM or email provider to go live.
        </p>
      </form>

      <aside class="contact-aside">
        <div class="card info-card">
          <h3>Talk to a human</h3>
          <ul class="contact-list">
            <li>
              <span class="ci-label">Email</span>
              <a href="mailto:hello@verapeakdigital.com">hello@verapeakdigital.com</a>
            </li>
            <li>
              <span class="ci-label">Phone</span>
              <a href="tel:+18005551234">(800) 555-1234</a>
            </li>
            <li>
              <span class="ci-label">Hours</span>
              <span>Mon–Fri, 9am–6pm ET</span>
            </li>
          </ul>
        </div>

        <div class="card promise-card">
          <h3>What happens next?</h3>
          <ol class="next-steps">
            <li>We review your goals and current setup.</li>
            <li>A quick intro call to make sure we're a fit.</li>
            <li>A tailored proposal with clear scope and pricing.</li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    background: radial-gradient(120% 120% at 80% 0%, var(--bg-tint) 0%, var(--bg) 55%);
    padding-block: clamp(56px, 8vw, 96px);
  }
  .page-hero h1 { margin: 14px 0 18px; }

  .contact-grid {
    display: grid;
    gap: 32px;
    align-items: start;
  }

  .contact-form { display: grid; gap: 20px; }
  .field-row { display: grid; gap: 20px; }
  .field { display: grid; gap: 7px; }
  label { font-weight: 600; font-size: 0.9rem; color: var(--ink); }
  input, select, textarea {
    font: inherit;
    color: var(--text);
    padding: 12px 14px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    background: var(--bg-soft);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--teal);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
  }
  textarea { resize: vertical; }
  .contact-form .btn { justify-self: start; }
  .form-note {
    color: var(--teal);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .contact-aside { display: grid; gap: 24px; }
  .info-card ul, .contact-list { list-style: none; display: grid; gap: 16px; }
  .contact-list li { display: grid; gap: 2px; }
  .ci-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 600;
  }
  .info-card a, .info-card span { font-size: 1.02rem; }

  .promise-card .next-steps {
    list-style: none;
    counter-reset: step;
    display: grid;
    gap: 14px;
    margin-top: 6px;
  }
  .next-steps li {
    counter-increment: step;
    position: relative;
    padding-left: 40px;
    color: var(--text);
    font-size: 0.96rem;
  }
  .next-steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: -2px;
    width: 26px;
    height: 26px;
    display: grid;
    place-items: center;
    background: var(--bg-tint);
    color: var(--teal);
    font-weight: 700;
    font-size: 0.85rem;
    border-radius: 50%;
  }

  @media (min-width: 600px) {
    .field-row { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 920px) {
    .contact-grid { grid-template-columns: 1.5fr 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const note = document.getElementById('form-note');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (note) note.hidden = false;
    form.reset();
  });
</script>
