---
import Base from '../layouts/Base.astro';
import ComingSoon from '../components/ComingSoon.astro';
import { COMING_SOON } from '../config';

const services = ['SEO', 'Paid Media & PPC', 'Web Design & Development', 'Analytics & CRO', 'Email & Lifecycle', 'Brand & Strategy', 'Not sure yet'];
const budgets = ['Under $2k / mo', '$2k to $5k / mo', '$5k to $10k / mo', '$10k+ / mo', 'One-off project'];
---

{COMING_SOON ? <ComingSoon /> : (
<Base title="Contact Verapeak Digital | Free Marketing Audit, Knoxville & US" description="Get a free growth audit and proposal from Verapeak Digital, a Knoxville-based marketing agency for small businesses nationwide. We reply within one business day.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about your <span class="text-grad">growth</span>.</h1>
      <p class="lead">
        Tell us where you are and where you want to be. Verapeak is based in Knoxville
        and works with small businesses nationwide. We reply within one business day
        with honest, actionable next steps, no pressure and no jargon.
      </p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact-grid">
      <form
        class="contact-form"
        id="contact-form"
        action="/api/contact"
        method="POST"
        data-reveal
      >
        <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;" />
        <div class="field-row">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required />
          </div>
          <div class="field">
            <label for="company">Company</label>
            <input id="company" name="company" type="text" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="field">
            <label for="website">Website</label>
            <input id="website" name="website" type="url" />
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="service">Primary interest</label>
            <select id="service" name="service">
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="budget">Monthly budget</label>
            <select id="budget" name="budget">
              {budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div class="field">
          <label for="message">How can we help?</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg">Send message</button>
        <p class="form-note" id="form-note" hidden>
          Thanks for reaching out. We will reply within one business day.
        </p>
        <p class="form-error" id="form-error" hidden>
          Something went wrong sending your message. Please email us directly at
          <a href="mailto:deanbishopsem@gmail.com">deanbishopsem@gmail.com</a>.
        </p>
      </form>

      <aside class="contact-aside" data-reveal style="--reveal-delay:100ms">
        <div class="info-card">
          <h3>Talk to a human</h3>
          <ul class="contact-list">
            <li>
              <span class="ci-label">Email</span>
              <a href="mailto:deanbishopsem@gmail.com">deanbishopsem@gmail.com</a>
            </li>
            <li>
              <span class="ci-label">Phone</span>
              <a href="tel:+18287675641">(828) 767-5641</a>
            </li>
            <li>
              <span class="ci-label">Hours</span>
              <span>Mon to Fri, 9am to 6pm ET</span>
            </li>
          </ul>
        </div>

        <div class="promise-card">
          <h3>What happens next?</h3>
          <ol class="next-steps">
            <li>We review your goals and current setup.</li>
            <li>A quick intro call to make sure we are a fit.</li>
            <li>A tailored proposal with clear scope and pricing.</li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</Base>
)}

<style>
  .page-hero {
    background: radial-gradient(80% 120% at 92% -10%, var(--bg-tint) 0%, transparent 52%), var(--bg);
    padding-block: clamp(48px, 7vw, 88px);
  }
  .page-hero h1 { margin: 10px 0 16px; }

  .contact-section { padding-top: clamp(40px, 5vw, 64px); }
  .contact-grid { display: grid; gap: 32px; align-items: start; }

  .contact-form {
    display: grid; gap: 20px; background: var(--paper); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 34px; box-shadow: var(--shadow-sm);
  }
  .field-row { display: grid; gap: 20px; }
  .field { display: grid; gap: 7px; }
  label { font-weight: 600; font-size: 0.9rem; color: var(--ink); }
  input, select, textarea {
    font: inherit; color: var(--text); padding: 13px 15px; border: 1.5px solid var(--border-strong);
    border-radius: 12px; background: var(--bg); transition: border-color 0.15s var(--ease), box-shadow 0.15s var(--ease);
  }
  input::placeholder, textarea::placeholder { color: var(--text-faint); }
  input:focus, select:focus, textarea:focus {
    outline: none; border-color: var(--teal); box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
  }
  textarea { resize: vertical; }
  .contact-form .btn { justify-self: start; }
  .form-note { color: var(--teal); font-weight: 600; font-size: 0.95rem; }
  .form-error { color: #c0392b; font-weight: 600; font-size: 0.95rem; }
  .form-error a { color: #c0392b; text-decoration: underline; }

  .contact-aside { display: grid; gap: 22px; }
  .info-card, .promise-card {
    background: var(--paper); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 30px;
  }
  .info-card h3, .promise-card h3 { margin-bottom: 18px; }
  .contact-list { list-style: none; display: grid; gap: 16px; }
  .contact-list li { display: grid; gap: 2px; }
  .ci-label { font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-faint); font-weight: 600; }
  .info-card a, .info-card span { font-size: 1.02rem; }

  .next-steps { list-style: none; counter-reset: step; display: grid; gap: 16px; }
  .next-steps li { counter-increment: step; position: relative; padding-left: 44px; font-size: 0.96rem; color: var(--text); }
  .next-steps li::before {
    content: counter(step); position: absolute; left: 0; top: -3px; width: 28px; height: 28px;
    display: grid; place-items: center; background: var(--bg-tint); color: var(--teal);
    font-family: var(--font-display); font-weight: 700; font-size: 0.85rem; border-radius: 50%;
  }

  @media (min-width: 600px) { .field-row { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 940px) { .contact-grid { grid-template-columns: 1.5fr 1fr; } }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const note = document.getElementById('form-note');
  const errorNote = document.getElementById('form-error');
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  // Show the success note if the visitor was redirected back after a no-JS submit.
  if (new URLSearchParams(location.search).get('sent') === '1' && note) {
    note.hidden = false;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (note) note.hidden = true;
    if (errorNote) errorNote.hidden = true;
    if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      if (res.ok) {
        // Redirect to the confirmation page so it can be tracked as a conversion.
        window.location.href = '/thank-you';
        return;
      } else if (errorNote) {
        errorNote.hidden = false;
      }
    } catch {
      if (errorNote) errorNote.hidden = false;
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Send message'; }
    }
  });
</script>
