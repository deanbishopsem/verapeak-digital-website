<script>
  // Scroll-scrubbed hero video: scroll position through the tall .hero section
  // drives video.currentTime. Smoothed with a lerp so seeks stay fluid.
  const hero = document.getElementById('hero');
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;

  if (hero && video) {
    let duration = 0;
    let current = 0;
    let active = false;
    let raf = 0;
    let primed = false;

    video.muted = true;
    video.setAttribute('playsinline', '');

    const onMeta = () => {
      duration = video.duration && isFinite(video.duration) ? video.duration : 8;
    };
    if (video.readyState >= 1) onMeta();
    else video.addEventListener('loadedmetadata', onMeta, { once: true });

    // Prime the decoder: a never-played video won't render frames when you seek it
    // on iOS/Safari (you'd see a blank hero). Playing for a split second then pausing
    // makes scrubbing via currentTime work on mobile too.
    const prime = () => {
      if (primed) return;
      primed = true;
      const settle = () => { video.pause(); try { video.currentTime = current || 0.0001; } catch (e) {} };
      const p = video.play();
      if (p && typeof p.then === 'function') p.then(() => setTimeout(settle, 120)).catch(settle);
      else settle();
    };
    if (video.readyState >= 2) prime();
    else video.addEventListener('loadeddata', prime, { once: true });
    // iOS may need a user gesture before it will play/decode
    document.addEventListener('touchstart', prime, { once: true, passive: true });

    const progress = () => {
      const total = hero.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(window.scrollY, 0), total);
      return total > 0 ? scrolled / total : 0;
    };

    const tick = () => {
      const target = progress() * (duration || 8);
      current += (target - current) * 0.15;
      if (Math.abs(target - current) < 0.004) current = target;
      if (primed && duration && isFinite(current)) {
        try { video.currentTime = current; } catch (e) {}
      }
      if (active) raf = requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !active) {
            active = true;
            raf = requestAnimationFrame(tick);
          } else if (!e.isIntersecting && active) {
            active = false;
            cancelAnimationFrame(raf);
          }
        });
      },
      { threshold: 0 }
    );
    io.observe(hero);
  }

  // Click-to-play the "what we do" commercial film (sound on, native controls).
  const wwdFilm = document.getElementById('wwd-film') as HTMLVideoElement | null;
  const wwdPlay = document.querySelector('.wwd-play') as HTMLButtonElement | null;
  if (wwdFilm && wwdPlay) {
    wwdPlay.addEventListener('click', () => {
      wwdFilm.controls = true;
      wwdFilm.muted = false;
      wwdPlay.classList.add('is-hidden');
      wwdFilm.play();
    });
    wwdFilm.addEventListener('ended', () => {
      wwdFilm.controls = false;
      wwdFilm.currentTime = 0;
      wwdPlay.classList.remove('is-hidden');
    });
  }
</script>
