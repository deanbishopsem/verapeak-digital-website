  .cta-banner {
    background:
      radial-gradient(120% 140% at 85% -20%, rgba(45, 212, 191, 0.25) 0%, transparent 55%),
      linear-gradient(120deg, var(--ink) 0%, var(--teal-dark) 130%);
    border-radius: 28px; padding: clamp(48px, 7vw, 88px); text-align: center;
    box-shadow: var(--shadow-lg);
  }
  .cta-banner h2 { color: #fff; }
