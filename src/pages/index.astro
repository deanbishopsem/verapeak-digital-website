---
import Base from '../layouts/Base.astro';

const stats = [
  { value: '4.8x', label: 'Average return on ad spend' },
  { value: '+212%', label: 'Organic traffic growth' },
  { value: '120+', label: 'Brands scaled' },
  { value: '98%', label: 'Client retention' },
];

const services = [
  {
    title: 'Search Engine Optimization',
    desc: 'Climb the rankings with technical SEO, content strategy, and authority building that compounds over time.',
    icon: '🔍',
  },
  {
    title: 'Paid Media & PPC',
    desc: 'High-intent campaigns across Google, Meta, and LinkedIn engineered for measurable return on every dollar.',
    icon: '🎯',
  },
  {
    title: 'Web Design & Development',
    desc: 'Fast, conversion-focused websites that turn visitors into customers and look great everywhere.',
    icon: '💻',
  },
  {
    title: 'Analytics & CRO',
    desc: 'Clean tracking, clear dashboards, and continuous testing so every decision is backed by data.',
    icon: '📈',
  },
];

const steps = [
  { n: '01', title: 'Discover', desc: 'We audit your funnel, market, and competitors to find the real growth levers.' },
  { n: '02', title: 'Strategize', desc: 'A custom roadmap with clear priorities, timelines, and KPIs you can hold us to.' },
  { n: '03', title: 'Execute', desc: 'Our specialists build, launch, and optimize campaigns across every channel.' },
  { n: '04', title: 'Scale', desc: 'We double down on what works and reinvest in the next peak of growth.' },
];
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">Data-Driven Digital Marketing</span>
        <h1>Reach the <span class="text-grad">peak</span> of your market.</h1>
        <p class="lead">
          Verapeak Digital builds marketing engines that drive real revenue — combining
          SEO, paid media, and conversion design into one accountable growth system.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">Get a Free Proposal</a>
          <a href="/services" class="btn btn-ghost">Explore Services</a>
        </div>
        <div class="hero-trust">
          <span>Trusted by ambitious teams in SaaS, e‑commerce, and B2B</span>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="chart-card">
          <div class="chart-head">
            <span>Revenue growth</span>
            <span class="chart-badge">▲ 212%</span>
          </div>
          <div class="bars">
            <span style="height: 32%"></span>
            <span style="height: 48%"></span>
            <span style="height: 41%"></span>
            <span style="height: 64%"></span>
            <span style="height: 78%"></span>
            <span style="height: 92%"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="container grid grid-4">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-value">{s.value}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">What we do</span>
        <h2>Full-funnel marketing under one roof</h2>
        <p class="lead" style="margin-inline:auto;">
          No silos, no hand-offs. One integrated team that owns your growth from
          first click to closed deal.
        </p>
      </div>
      <div class="grid grid-2">
        {services.map((s) => (
          <article class="card service-card">
            <div class="service-icon">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <a href="/services" class="card-link">Learn more →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section process">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">How we work</span>
        <h2>A proven path to the peak</h2>
      </div>
      <div class="grid grid-4">
        {steps.map((step) => (
          <div class="step">
            <div class="step-n">{step.n}</div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <h2>Ready to climb?</h2>
        <p>Get a free, no-obligation growth audit and a clear plan to hit your next peak.</p>
        <a href="/contact" class="btn btn-primary">Start the Conversation</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: radial-gradient(120% 120% at 80% 0%, var(--bg-tint) 0%, var(--bg) 55%);
    padding-block: clamp(48px, 7vw, 90px);
  }
  .hero-inner {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  .hero-copy h1 { margin: 14px 0 20px; }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
  .hero-trust {
    margin-top: 32px;
    font-size: 0.9rem;
    color: var(--text-muted);
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .hero-visual { display: flex; justify-content: center; }
  .chart-card {
    width: 100%;
    max-width: 420px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-lg);
  }
  .chart-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 22px;
    font-weight: 600;
    color: var(--ink);
  }
  .chart-badge {
    font-size: 0.85rem;
    color: var(--teal);
    background: var(--bg-tint);
    padding: 4px 10px;
    border-radius: 999px;
  }
  .bars {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    align-items: end;
    gap: 12px;
    height: 200px;
  }
  .bars span {
    display: block;
    border-radius: 8px 8px 4px 4px;
    background: linear-gradient(180deg, var(--mint-light), var(--teal));
  }
  .bars span:last-child {
    background: linear-gradient(180deg, var(--mint), var(--teal-dark));
  }

  .stats {
    border-block: 1px solid var(--border);
    background: var(--bg-soft);
    padding-block: 48px;
  }
  .stat { text-align: center; }
  .stat-value {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--teal);
    letter-spacing: -0.03em;
  }
  .stat-label { font-size: 0.92rem; margin-top: 4px; }

  .service-card { display: flex; flex-direction: column; }
  .service-icon {
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    background: var(--bg-tint);
    border-radius: 14px;
    margin-bottom: 18px;
  }
  .service-card p { margin: 8px 0 18px; }
  .card-link { font-weight: 600; margin-top: auto; }

  .process { background: var(--bg-soft); }
  .step-n {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--mint);
    margin-bottom: 8px;
  }
  .step h3 { margin-bottom: 8px; }

  .cta-banner {
    background: linear-gradient(120deg, var(--ink), var(--teal-dark));
    border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 72px);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }
  .cta-banner h2 { color: #fff; }
  .cta-banner p { color: #bfe0dc; margin: 14px auto 28px; max-width: 46ch; }

  @media (min-width: 920px) {
    .hero-inner { grid-template-columns: 1.05fr 0.95fr; }
  }
</style>
