---
import Base from '../layouts/Base.astro';

const values = [
  { title: 'Outcomes over outputs', desc: 'We measure success in revenue and pipeline — not impressions, vanity metrics, or busywork.' },
  { title: 'Radical transparency', desc: 'Live dashboards, plain-English reporting, and honest conversations even when the news is hard.' },
  { title: 'Senior by default', desc: 'The specialists who win your business are the ones who do the work. No junior hand-offs.' },
  { title: 'Compounding growth', desc: 'We build durable marketing assets that keep paying off long after the campaign ends.' },
];

const team = [
  { name: 'Maya Renner', role: 'Founder & Growth Strategist', initials: 'MR' },
  { name: 'Daniel Cho', role: 'Head of Paid Media', initials: 'DC' },
  { name: 'Priya Anand', role: 'SEO & Content Lead', initials: 'PA' },
  { name: 'Liam Torres', role: 'Design & CRO', initials: 'LT' },
];
---

<Base title="About — Verapeak Digital" description="Meet Verapeak Digital — a senior team of marketers, strategists, and designers obsessed with measurable growth.">
  <section class="page-hero">
    <div class="container about-hero">
      <div>
        <span class="eyebrow">About us</span>
        <h1>We help good brands reach their <span class="text-grad">peak</span>.</h1>
        <p class="lead">
          Verapeak Digital was founded on a simple belief: marketing should be
          accountable. We pair the creativity of an agency with the rigor of a
          performance team — so every dollar you invest can be traced to a result.
        </p>
      </div>
      <div class="about-figure" aria-hidden="true">
        <img src="/assets/logo-square.svg" alt="" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-2 mission">
      <div>
        <span class="eyebrow">Our story</span>
        <h2>From scrappy startup to growth partner</h2>
      </div>
      <div class="mission-body">
        <p>
          We started Verapeak after years inside high-growth companies, frustrated by
          agencies that optimized for retainers instead of results. So we built the
          partner we always wished we'd had — small, senior, and relentlessly focused
          on the numbers that matter.
        </p>
        <p>
          Today we work with ambitious SaaS, e-commerce, and B2B teams across the
          country, treating every client's budget like our own and every campaign as
          a step toward their next peak.
        </p>
      </div>
    </div>
  </section>

  <section class="section values">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">What we believe</span>
        <h2>The values behind the work</h2>
      </div>
      <div class="grid grid-2">
        {values.map((v) => (
          <div class="card">
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">The team</span>
        <h2>Senior people who do the work</h2>
      </div>
      <div class="grid grid-4">
        {team.map((m) => (
          <div class="member">
            <div class="avatar">{m.initials}</div>
            <h3>{m.name}</h3>
            <p>{m.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <h2>Let's build something that climbs.</h2>
        <p>We take on a limited number of partners each quarter to keep our work senior and focused.</p>
        <a href="/contact" class="btn btn-primary">Work With Us</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    background: radial-gradient(120% 120% at 80% 0%, var(--bg-tint) 0%, var(--bg) 55%);
    padding-block: clamp(56px, 8vw, 96px);
  }
  .about-hero { display: grid; gap: 40px; align-items: center; }
  .about-hero h1 { margin: 14px 0 18px; }
  .about-figure {
    display: flex;
    justify-content: center;
  }
  .about-figure img {
    width: 100%;
    max-width: 320px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .mission { align-items: start; }
  .mission-body { display: grid; gap: 18px; }

  .values { background: var(--bg-soft); }

  .member { text-align: center; }
  .avatar {
    width: 84px;
    height: 84px;
    margin: 0 auto 16px;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 1.4rem;
    color: #fff;
    background: linear-gradient(135deg, var(--teal), var(--mint));
    border-radius: 50%;
  }
  .member h3 { font-size: 1.1rem; }
  .member p { font-size: 0.92rem; }

  .cta-banner {
    background: linear-gradient(120deg, var(--ink), var(--teal-dark));
    border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 72px);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }
  .cta-banner h2 { color: #fff; }
  .cta-banner p { color: #bfe0dc; margin: 14px auto 28px; max-width: 50ch; }

  @media (min-width: 860px) {
    .about-hero { grid-template-columns: 1.3fr 0.7fr; }
  }
</style>
