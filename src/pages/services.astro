---
import Base from '../layouts/Base.astro';

const services = [
  {
    icon: '🔍',
    title: 'Search Engine Optimization',
    desc: 'Sustainable organic growth built on technical excellence, intent-driven content, and authoritative links.',
    points: ['Technical & on-page SEO', 'Content strategy & production', 'Digital PR & link building', 'Local & e-commerce SEO'],
  },
  {
    icon: '🎯',
    title: 'Paid Media & PPC',
    desc: 'Full-funnel paid campaigns that put your budget where the return is — and prove it with clean attribution.',
    points: ['Google & Bing Ads', 'Meta & LinkedIn Ads', 'Retargeting & display', 'Shopping & performance max'],
  },
  {
    icon: '💻',
    title: 'Web Design & Development',
    desc: 'Conversion-first websites and landing pages that load fast, rank well, and turn traffic into revenue.',
    points: ['Landing page design', 'Website builds (Astro, Webflow, WP)', 'Conversion rate optimization', 'Core Web Vitals & speed'],
  },
  {
    icon: '📈',
    title: 'Analytics & Reporting',
    desc: 'A single source of truth for your marketing — accurate tracking and dashboards everyone can trust.',
    points: ['GA4 & server-side tracking', 'Custom KPI dashboards', 'Attribution modeling', 'Experimentation & A/B testing'],
  },
  {
    icon: '✉️',
    title: 'Email & Lifecycle',
    desc: 'Automated journeys that nurture leads and turn one-time buyers into loyal, repeat customers.',
    points: ['Lifecycle automation', 'Newsletter & broadcast', 'Segmentation & personalization', 'Deliverability optimization'],
  },
  {
    icon: '🧭',
    title: 'Brand & Strategy',
    desc: 'Positioning, messaging, and creative that make your brand impossible to ignore in a crowded market.',
    points: ['Positioning & messaging', 'Creative & ad concepts', 'Go-to-market strategy', 'Competitive research'],
  },
];
---

<Base title="Services — Verapeak Digital" description="Explore Verapeak Digital's full-service marketing offering: SEO, paid media, web design, analytics, email, and brand strategy.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Services</span>
      <h1>Everything you need to grow, <span class="text-grad">nothing you don't</span>.</h1>
      <p class="lead">
        Pick a single channel or hand us the whole funnel. Either way you get a senior,
        integrated team obsessed with one thing: your results.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-3">
      {services.map((s) => (
        <article class="card service-detail">
          <div class="service-icon">{s.icon}</div>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
          <ul>
            {s.points.map((p) => <li>{p}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section pricing">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Engagements</span>
        <h2>Flexible ways to work together</h2>
      </div>
      <div class="grid grid-3">
        <div class="card plan">
          <h3>Project</h3>
          <p class="plan-price">Fixed scope</p>
          <p>A defined deliverable — a website, an audit, a campaign launch — with a clear timeline and price.</p>
          <a href="/contact" class="btn btn-ghost">Discuss a project</a>
        </div>
        <div class="card plan featured">
          <span class="plan-tag">Most popular</span>
          <h3>Retainer</h3>
          <p class="plan-price">Monthly partnership</p>
          <p>An ongoing growth team across one or more channels, with monthly reporting and strategy.</p>
          <a href="/contact" class="btn btn-primary">Build a retainer</a>
        </div>
        <div class="card plan">
          <h3>Consulting</h3>
          <p class="plan-price">Advisory</p>
          <p>Strategic guidance and audits for in-house teams that want senior expertise on demand.</p>
          <a href="/contact" class="btn btn-ghost">Book a session</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <h2>Not sure which service fits?</h2>
        <p>Tell us your goals and we'll recommend the highest-impact next step — free of charge.</p>
        <a href="/contact" class="btn btn-primary">Get a Recommendation</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    background: radial-gradient(120% 120% at 80% 0%, var(--bg-tint) 0%, var(--bg) 55%);
    padding-block: clamp(56px, 8vw, 96px);
  }
  .page-hero h1 { margin: 14px 0 18px; }

  .service-icon {
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    background: var(--bg-tint);
    border-radius: 14px;
    margin-bottom: 18px;
  }
  .service-detail p { margin: 8px 0 16px; }
  .service-detail ul { list-style: none; display: grid; gap: 10px; }
  .service-detail li {
    position: relative;
    padding-left: 26px;
    color: var(--text);
    font-size: 0.95rem;
  }
  .service-detail li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--teal);
    font-weight: 700;
  }

  .pricing { background: var(--bg-soft); }
  .plan { display: flex; flex-direction: column; gap: 6px; position: relative; }
  .plan p { margin-bottom: 8px; }
  .plan .btn { margin-top: auto; justify-content: center; }
  .plan-price { color: var(--teal); font-weight: 600; }
  .plan.featured { border-color: var(--teal); box-shadow: var(--shadow-lg); }
  .plan-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--teal);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 999px;
  }

  .cta-banner {
    background: linear-gradient(120deg, var(--ink), var(--teal-dark));
    border-radius: var(--radius-lg);
    padding: clamp(40px, 6vw, 72px);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }
  .cta-banner h2 { color: #fff; }
  .cta-banner p { color: #bfe0dc; margin: 14px auto 28px; max-width: 46ch; }
</style>
