---
import Base from '../layouts/Base.astro';
import ComingSoon from '../components/ComingSoon.astro';
import HeroViz from '../components/HeroViz.astro';
import Aurora from '../components/Aurora.astro';
import { COMING_SOON } from '../config';
import { services } from '../data/services';

const plans = [
  { name: 'Project', price: 'Fixed scope', desc: 'A defined deliverable with a clear timeline and price. A website, an audit, a campaign launch.', cta: 'Discuss a project', featured: false },
  { name: 'Retainer', price: 'Monthly partnership', desc: 'An ongoing growth team across one or more channels, with monthly reporting and strategy.', cta: 'Build a retainer', featured: true },
  { name: 'Consulting', price: 'Advisory', desc: 'Strategic guidance and audits for in-house teams that want senior expertise on demand.', cta: 'Book a session', featured: false },
];
---

{COMING_SOON ? <ComingSoon /> : (
<Base title="Digital Marketing Services for Small Business | Verapeak" description="SEO, paid media (PPC), web design, analytics, email, and brand strategy for small businesses. One senior, transparent team based in Knoxville, serving clients nationwide.">
  <section class="page-hero">
    <div class="container">
      <div class="ph-grid">
        <div data-reveal>
          <span class="eyebrow">Digital marketing services</span>
          <h1>Everything you need to grow, <span class="text-grad">nothing you don't</span>.</h1>
          <p class="lead">
            Pick a single channel or hand us the whole funnel. Either way, small
            businesses get a senior, transparent team obsessed with one thing: your
            results, with a live dashboard showing where every dollar goes.
          </p>
          <a href="/contact" class="btn btn-primary btn-lg">Get a proposal</a>
        </div>
        <div class="ph-anim" data-reveal style="--reveal-delay:120ms">
          <HeroViz variant="growth" />
        </div>
      </div>
    </div>
  </section>

  <section class="section svc-section">
    <div class="container">
      <div class="svc-list">
        {services.map((s, i) => (
          <a href={`/services/${s.slug}`} class="svc-card" data-reveal style={`--reveal-delay:${(i % 2) * 70}ms`}>
            <span class="svc-tag">{s.tag}</span>
            <h3>{s.name}</h3>
            <p>{s.cardDesc}</p>
            <ul>
              {s.includes.slice(0, 4).map((inc) => <li>{inc.h}</li>)}
            </ul>
            <span class="svc-card-link">View {s.name.toLowerCase()} <span aria-hidden="true">&rarr;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section pricing">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="eyebrow">Engagements</span>
        <h2>Flexible ways to work together</h2>
      </div>
      <div class="grid grid-3">
        {plans.map((p, i) => (
          <div class:list={['plan', { featured: p.featured }]} data-reveal style={`--reveal-delay:${i * 70}ms`}>
            {p.featured && <span class="plan-tag">Most popular</span>}
            <h3>{p.name}</h3>
            <p class="plan-price">{p.price}</p>
            <p class="plan-desc">{p.desc}</p>
            <a href="/contact" class:list={['btn', p.featured ? 'btn-primary' : 'btn-ghost']}>{p.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-banner" data-reveal>
        <h2>Not sure which fits?</h2>
        <p>Tell us your goals and we will recommend the highest-impact next step, free of charge.</p>
        <a href="/contact" class="btn btn-primary btn-lg">Get a proposal</a>
      </div>
    </div>
  </section>
</Base>
)}

<style>
  .page-hero {
    background: radial-gradient(80% 120% at 92% -10%, var(--bg-tint) 0%, transparent 52%), var(--bg);
    padding-block: clamp(48px, 7vw, 88px);
  }
  .ph-grid { display: grid; gap: 40px; align-items: center; }
  .page-hero h1 { margin: 10px 0 18px; }
  .page-hero .btn { margin-top: 30px; }
  .ph-photo img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); aspect-ratio: 9/10; object-fit: cover; }

  .svc-list { display: grid; gap: 20px; grid-template-columns: 1fr; }
  .svc-card {
    display: flex; flex-direction: column; color: inherit; text-decoration: none;
    background: var(--paper); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 32px; transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .svc-card:hover { transform: translateY(-5px); box-shadow: var(--shadow); border-color: var(--border-strong); }
  .svc-card-link { margin-top: 18px; font-weight: 600; font-size: 0.95rem; color: var(--teal); }
  .svc-tag {
    display: inline-block; font-size: 0.74rem; font-weight: 600; color: var(--teal);
    background: var(--bg-tint); padding: 5px 11px; border-radius: var(--radius-pill); margin-bottom: 16px;
  }
  .svc-card h3 { margin-bottom: 8px; }
  .svc-card p { margin-bottom: 18px; }
  .svc-card ul { list-style: none; display: grid; gap: 9px; }
  .svc-card li { position: relative; padding-left: 24px; font-size: 0.93rem; color: var(--text); }
  .svc-card li::before { content: ''; position: absolute; left: 0; top: 9px; width: 10px; height: 5px; border-left: 2px solid var(--teal); border-bottom: 2px solid var(--teal); transform: rotate(-45deg); }

  .pricing { background: var(--bg-soft); }
  .plan {
    background: var(--paper); border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 36px 32px; display: flex; flex-direction: column; gap: 8px; position: relative;
  }
  .plan .btn { margin-top: auto; justify-content: center; }
  .plan-price { color: var(--teal); font-weight: 600; margin-bottom: 6px; }
  .plan-desc { margin-bottom: 22px; }
  .plan.featured { border-color: var(--teal); box-shadow: var(--shadow); }
  .plan-tag {
    position: absolute; top: -13px; left: 50%; transform: translateX(-50%);
    background: var(--teal); color: #fff; font-size: 0.74rem; font-weight: 600;
    padding: 5px 14px; border-radius: var(--radius-pill);
  }

  .cta-section { padding-top: 0; }
  .cta-banner {
    background: radial-gradient(120% 140% at 85% -20%, rgba(45, 212, 191, 0.25) 0%, transparent 55%),
      linear-gradient(120deg, var(--ink) 0%, var(--teal-dark) 130%);
    border-radius: 28px; padding: clamp(48px, 7vw, 88px); text-align: center; box-shadow: var(--shadow-lg);
  }
  .cta-banner h2 { color: #fff; }
  .cta-banner p { color: #bfe0dc; margin: 16px auto 30px; max-width: 46ch; }

  @media (min-width: 760px) {
    .svc-list { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 940px) {
    .ph-grid { grid-template-columns: 1.05fr 0.95fr; gap: 60px; }
  }
</style>
