---
import Base from '../layouts/Base.astro';

const features = [
  {
    title: 'Funnels & lead attribution',
    desc: 'Every form fill, phone call, and chat is captured and attributed to the marketing channel it came from — organic, paid search, paid social, email, referral, or direct.',
  },
  {
    title: 'ROI by channel',
    desc: 'Ad spend, leads, closed deals, and revenue rolled up per channel, so you always know your cost per lead, ROAS, and true return on investment.',
  },
  {
    title: 'Google Analytics 4 & Search Console',
    desc: 'Traffic, engagement, and organic search performance sync automatically every day from your Google properties (read-only).',
  },
  {
    title: 'Google Ads & Meta',
    desc: 'Paid campaign spend and performance from Google Ads, Facebook, and Instagram feed the same ROI view (read-only reporting).',
  },
  {
    title: 'Calls, forms & CRM deals',
    desc: 'First-party call tracking, website form capture, and closed-won revenue from your CRM complete the picture from click to customer.',
  },
  {
    title: 'Private client workspaces',
    desc: 'Each client signs in to their own secure dashboard and sees only their own data — isolated at the database level.',
  },
];
---

<Base
  title="Verapeak Insights | Client Marketing Reporting Dashboard"
  description="Verapeak Insights is Verapeak Digital's client reporting platform: one secure dashboard for funnels, lead attribution, and ROI by channel, with read-only data from Google Analytics 4, Search Console, Google Ads, Meta, call tracking, and your CRM."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Our platform</span>
      <h1>Verapeak <span class="text-grad">Insights</span></h1>
      <p class="lead">
        Verapeak Insights is the client reporting dashboard built and operated by Verapeak
        Digital. Its purpose is simple: give every client one secure, always-current view of
        their marketing performance — where leads come from, what each channel costs, and the
        revenue it returns — so every marketing dollar is traced to real results.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="https://app.verapeakdigital.com/login">Client sign in</a>
        <a class="btn btn-ghost btn-lg" href="/contact">Become a client</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="ins-h2">What Verapeak Insights does</h2>
      <div class="ins-grid">
        {features.map((f) => (
          <div class="ins-card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section ins-how">
    <div class="container">
      <h2 class="ins-h2">How it works with your Google data</h2>
      <p class="ins-note">
        When a client connects Google Analytics 4, Search Console, or Google Ads, Verapeak
        Insights requests <strong>read-only</strong> access and syncs performance metrics once a
        day into that client's private workspace. The data is used solely to report that
        client's own marketing results back to them. It is never sold, shared with third
        parties, or used to modify campaigns. See our
        <a href="/privacy">Privacy Policy</a> for full details on how data is collected,
        stored, and protected.
      </p>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    background: radial-gradient(80% 120% at 92% -10%, var(--bg-tint) 0%, transparent 52%), var(--bg);
    padding-block: clamp(48px, 7vw, 88px);
  }
  .page-hero h1 { margin: 10px 0 16px; }
  .page-hero .lead { max-width: 62ch; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }

  .ins-h2 { margin-bottom: 26px; }
  .ins-grid { display: grid; gap: 18px; }
  .ins-card {
    background: var(--paper); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 26px;
  }
  .ins-card h3 { margin-bottom: 8px; font-size: 1.05rem; }
  .ins-card p { color: var(--text-muted); font-size: 0.96rem; line-height: 1.6; }

  .ins-how { padding-bottom: 96px; }
  .ins-note { max-width: 72ch; color: var(--text); line-height: 1.7; }
  .ins-note a { color: var(--teal); text-decoration: underline; text-underline-offset: 2px; }

  @media (min-width: 720px) { .ins-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ins-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
