---
import Base from '../../layouts/Base.astro';
import ComingSoon from '../../components/ComingSoon.astro';
import HeroViz from '../../components/HeroViz.astro';
import Aurora from '../../components/Aurora.astro';
import { COMING_SOON } from '../../config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

{COMING_SOON ? <ComingSoon /> : (
<Base
  title="Marketing Blog for Small Businesses | Verapeak Digital"
  description="Practical, no-jargon marketing guides for small businesses: paid media, SEO, analytics, and behavioral health marketing from Verapeak Digital in Knoxville."
>
  <section class="page-hero">
    <div class="container">
      <div class="blog-hero-grid">
        <div>
          <span class="eyebrow">Blog</span>
          <h1>Marketing, <span class="text-grad">minus the jargon</span>.</h1>
          <p class="lead">
            Practical guides for small business owners who want marketing that works and
            numbers they can actually trust.
          </p>
        </div>
        <div class="blog-hero-viz" data-reveal style="--reveal-delay:120ms">
          <HeroViz variant="blog" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="post-list">
        {posts.map((p, i) => (
          <a href={`/blog/${p.slug}`} class="post-card" data-reveal style={`--reveal-delay:${i * 60}ms`}>
            <img class="post-cover" style="display:block;width:100%;height:auto;aspect-ratio:auto;object-fit:fill;" src={`${p.data.heroImage}?v=3`} alt={p.data.heroImageAlt} width="1200" height="400" loading="lazy" />
            <div class="post-body">
              <div class="post-meta">{fmt(p.data.pubDate)}{p.data.tags[0] ? ` · ${p.data.tags[0]}` : ''}</div>
              <h2>{p.data.title}</h2>
              <p>{p.data.description}</p>
              <span class="post-link">Read more <span aria-hidden="true">&rarr;</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
)}

<style>
  .page-hero {
    background: radial-gradient(80% 120% at 92% -10%, var(--bg-tint) 0%, transparent 52%), var(--bg);
    padding-block: clamp(48px, 7vw, 88px);
  }
  .page-hero h1 { margin: 10px 0 16px; }
  .blog-hero-grid { display: grid; gap: 40px; align-items: center; }
  @media (min-width: 920px) { .blog-hero-grid { grid-template-columns: 1.05fr 0.95fr; gap: 56px; } }
  .post-list { display: grid; gap: 26px; max-width: 1040px; margin: 0 auto; }
  .post-card {
    display: flex; flex-direction: column; color: inherit; text-decoration: none; overflow: hidden;
    background: var(--paper); border: 1px solid var(--border); border-radius: var(--radius-lg);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .post-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); border-color: var(--border-strong); }
  /* banner cover shown at its natural 3:1 ratio, never cropped */
  .post-cover { width: 100%; height: auto; display: block; background: var(--ink); }
  .post-body { display: flex; flex-direction: column; gap: 10px; padding: 24px 28px 28px; }
  .post-meta { font-size: 0.85rem; color: var(--text-faint); font-weight: 500; }
  .post-card h2 { font-size: 1.35rem; line-height: 1.15; }
  .post-card p { color: var(--text-muted); font-size: 0.96rem; }
  .post-link { font-weight: 600; font-size: 0.95rem; color: var(--teal); margin-top: auto; padding-top: 6px; }
  @media (min-width: 720px) {
    .post-list { grid-template-columns: 1fr 1fr; }
  }
</style>
